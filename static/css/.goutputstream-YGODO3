    background: #16a34a;
    color: white;
    box-shadow: 0 2px 4px rgba(22,163,74,0.2);
}

.etr-risk-badge.medium {
    background: #e67e22;
    color: white;
    box-shadow: 0 2px 4px rgba(230,126,34,0.2);
}

.etr-risk-badge.high {
    background: #dc2626;
    color: white;
    box-shadow: 0 2px 4px rgba(220,38,38,0.2);
}

