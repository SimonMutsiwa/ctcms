.etr-stats {
    display: flex;
    justify-content: space-between;
    gap: 15px;
    margin: 15px 0;
    padding: 12px 0;
    border-top: 1px solid rgba(0,0,0,0.05);
    border-bottom: 1px solid rgba(0,0,0,0.05);
