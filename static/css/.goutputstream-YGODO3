    color: #1a2c3e;
}

.risk-score-badge {
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
}

.risk-score-badge.high {
    background: #dc2626;
    color: white;
}

.risk-score-badge.medium {
    background: #e67e22;
    color: white;
}

.risk-score-badge.low {
    background: #16a34a;
    color: white;
}

.risk-company-body {
    padding: 16px 20px;
    background: white;
}

.risk-metrics {
    display: flex;
    justify-content: space-between;
    margin-bottom: 15px;
    padding-bottom: 12px;
    border-bottom: 1px solid #e2e8f0;
}

.risk-metric {
    text-align: center;
    flex: 1;
}

.risk-metric-label {
    font-size: 11px;
    color: #64748b;
    text-transform: uppercase;
    margin-bottom: 4px;
}

.risk-metric-value {
    font-size: 20px;
    font-weight: 700;
}

.risk-actions {
    display: flex;
    gap: 10px;
    margin-top: 12px;
}

.risk-btn {
    flex: 1;
    padding: 8px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    text-align: center;
    border: none;
}

.risk-btn-primary {
    background: #1a472a;
    color: white;
}

.risk-btn-primary:hover {
    background: #0e2a1a;
}

.risk-btn-secondary {
    background: #e2e8f0;
    color: #1a2c3e;
}

.risk-btn-secondary:hover {
    background: #cbd5e1;
}

/* Validation Issues List */
.validation-list {
    max-height: 500px;
    overflow-y: auto;
}

.validation-item {
    padding: 12px;
    border-left: 3px solid;
    margin-bottom: 10px;
    background: #f8fafc;
    border-radius: 8px;
}

.validation-item.high {
    border-left-color: #dc2626;
    background: #fee2e2;
}

.validation-item.medium {
    border-left-color: #e67e22;
    background: #fff3e0;
}

.validation-item.low {
    border-left-color: #16a34a;
    background: #e6f9e6;
}

/* Dark Mode */
body.dark-mode .risk-company-card {
    background: #16213e;
}

body.dark-mode .risk-company-body {
    background: #16213e;
}

body.dark-mode .risk-company-header.high {
    background: linear-gradient(135deg, #3a1a1a 0%, #4a1a1a 100%);
}

body.dark-mode .risk-company-header.medium {
    background: linear-gradient(135deg, #3a2a1a 0%, #4a3a1a 100%);
}

body.dark-mode .risk-company-header.low {
    background: linear-gradient(135deg, #1a3a1a 0%, #1a4a1a 100%);
}
.logout-btn:hover {
    background: rgba(255,255,255,0.2) !important;
}