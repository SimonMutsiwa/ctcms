    "\n",
    "# In[26]:\n",
    "\n",
    "\n",
    "def predict_behavior(company_data, model_path=MODEL_SAVE_PATH):\n",
    "    \"\"\"\n",
    "    Predict risk level for a single company.\n",
    "\n",
    "    Parameters\n",
    "    ----------\n",
    "    company_data : dict\n",
    "        Must contain raw columns: Revenue, Expenses, Profit, Tax_Liability,\n",
    "        Tax_Paid, Late_Filings, Compliance_Violations, Tax_Compliance_Ratio,\n",
    "        Audit_Findings, Audit_to_Tax_Ratio\n",
    "    model_path : str\n",
    "        Path to saved model artifact.\n",
    "\n",
    "    Returns\n",
    "    -------\n",
    "    dict with risk_level, confidence, risk_probabilities, top_risk_factors\n",
    "    \"\"\"\n",
    "    artifact = joblib.load(model_path)\n",
    "    model = artifact['model']\n",
    "    scaler = artifact['scaler']\n",
    "    feature_names = artifact['feature_names']\n",
    "    le = artifact['label_encoder']\n",
    "\n",
    "    # Feature engineering\n",
    "    helper = BehavioralRiskModel()\n",
    "    df_input = pd.DataFrame([company_data])\n",
    "    X = helper.prepare_features(df_input)\n",
    "\n",
    "    for f in feature_names:\n",
    "        if f not in X.columns:\n",
    "            X[f] = 0\n",
    "    X = X[feature_names]\n",
    "\n",
