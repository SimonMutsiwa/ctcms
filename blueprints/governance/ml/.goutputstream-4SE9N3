    "#!/usr/bin/env python\n",
    "# coding: utf-8\n",
    "\n",
    "# # Behavioral Analytics ML Model\n",
    "# ## Predicting Tax Compliance Behaviors from Financial & Governance Patterns\n",
    "#\n",
    "# This notebook trains a Random Forest classifier to detect risky tax behaviors\n",
    "# based on financial ratios, compliance metrics, and audit indicators.\n",
    "\n",
    "# ---\n",
    "# ## 1. Setup & Imports\n",
    "\n",
    "# In[1]:\n",
    "\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import warnings\n",
    "import os\n",
    "from pathlib import Path\n",
    "\n",
    "from sklearn.ensemble import RandomForestClassifier\n",
    "from sklearn.preprocessing import StandardScaler, LabelEncoder\n",
    "from sklearn.model_selection import train_test_split, cross_val_score, learning_curve\n",
    "from sklearn.metrics import (\n",
    "    classification_report, confusion_matrix, roc_auc_score,\n",
    "    precision_recall_curve, roc_curve, f1_score\n",
    ")\n",
    "from sklearn.inspection import permutation_importance\n",
    "import joblib\n",
    "\n",
    "warnings.filterwarnings('ignore')\n",
    "sns.set_style(\"whitegrid\")\n",
    "plt.rcParams['figure.figsize'] = (12, 6)\n",
    "plt.rcParams['font.size'] = 12\n",
    "\n",
    "print(\"All libraries loaded successfully.\")\n",
    "\n",
    "\n",
    "# ---\n",
    "# ## 2. Configuration\n",
    "\n",
    "# In[2]:\n",
    "\n",
    "\n",
    "# ============================================================\n",
    "# CONFIGURE THESE PATHS\n",
    "# ============================================================\n",
    "DATA_PATH = \"dataset.csv\"          # <-- Your CSV file path\n",
    "MODEL_SAVE_DIR = \"models\"\n",
    "MODEL_SAVE_PATH = os.path.join(MODEL_SAVE_DIR, \"behavioral_model.pkl\")\n",
    "\n",
    "# Create output directories\n",
    "os.makedirs(MODEL_SAVE_DIR, exist_ok=True)\n",
    "os.makedirs(\"plots\", exist_ok=True)\n",
    "\n",
    "print(f\"Data path:    {DATA_PATH}\")\n",
    "print(f\"Model output: {MODEL_SAVE_PATH}\")\n",
    "\n",
    "\n",
    "# ---\n",
    "# ## 3. Data Loading & Exploration\n",
    "\n",
    "# In[3]:\n",
    "\n",
    "\n",
    "df = pd.read_csv(DATA_PATH)\n",
    "print(f\"Dataset shape: {df.shape}\")\n",
    "print(f\"Memory usage:  {df.memory_usage(deep=True).sum() / 1024:.1f} KB\")\n",
    "df.head(10)\n",
    "\n",
    "\n",
    "# In[4]:\n",
    "\n",
    "\n",
    "print(\"Column types:\")\n",
    "print(df.dtypes)\n",
    "print(f\"\\nMissing values:\\n{df.isnull().sum()}\")\n",
    "\n",
    "\n",
    "# In[5]:\n",
    "\n",
    "\n",
    "# Basic statistics for numeric columns\n",
    "df.describe().round(2)\n",
    "\n",
    "\n",
    "# In[6]:\n",
    "\n",
    "\n",
    "# Target distribution\n",
    "print(\"=== Risk Label Distribution ===\")\n",
    "label_counts = df['Risk_Label'].value_counts()\n",
    "print(label_counts)\n",
    "print(f\"\\nPercentages:\")\n",
    "print((label_counts / len(df) * 100).round(1))\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# Bar chart\n",
    "colors = ['#2ecc71', '#e74c3c', '#f39c12']\n",
    "label_counts.plot(kind='bar', ax=axes[0], color=colors[:len(label_counts)], edgecolor='black')\n",
    "axes[0].set_title('Risk Label Distribution', fontsize=14, fontweight='bold')\n",
    "axes[0].set_xlabel('Risk Label')\n",
    "axes[0].set_ylabel('Count')\n",
    "axes[0].tick_params(axis='x', rotation=0)\n",
    "\n",
    "# Pie chart\n",
    "axes[1].pie(label_counts.values, labels=label_counts.index, autopct='%1.1f%%',\n",
    "            colors=colors[:len(label_counts)], startangle=90, explode=[0.05]*len(label_counts))\n",
    "axes[1].set_title('Risk Label Proportions', fontsize=14, fontweight='bold')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('plots/01_target_distribution.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "\n",
    "# In[7]:\n",
    "\n",
    "\n",
    "# Distribution of raw input features\n",
    "raw_features = ['Revenue', 'Expenses', 'Profit', 'Tax_Liability', 'Tax_Paid',\n",
    "                'Late_Filings', 'Compliance_Violations', 'Tax_Compliance_Ratio',\n",
    "                'Audit_Findings', 'Audit_to_Tax_Ratio']\n",
    "\n",
    "available_raw = [f for f in raw_features if f in df.columns]\n",
    "n_features = len(available_raw)\n",
    "n_cols = 3\n",
    "n_rows = (n_features + n_cols - 1) // n_cols\n",
    "\n",
    "fig, axes = plt.subplots(n_rows, n_cols, figsize=(18, 4 * n_rows))\n",
    "axes = axes.flatten()\n",
    "\n",
    "for i, col in enumerate(available_raw):\n",
    "    ax = axes[i]\n",
    "    for label in df['Risk_Label'].unique():\n",
    "        subset = df[df['Risk_Label'] == label][col].dropna()\n",
    "        ax.hist(subset, bins=30, alpha=0.5, label=str(label), edgecolor='black', linewidth=0.5)\n",
    "    ax.set_title(col, fontsize=12, fontweight='bold')\n",
    "    ax.legend(fontsize=9)\n",
    "    ax.set_ylabel('Count')\n",
    "\n",
    "for j in range(i + 1, len(axes)):\n",
    "    axes[j].set_visible(False)\n",
    "\n",
    "plt.suptitle('Raw Feature Distributions by Risk Label', fontsize=16, fontweight='bold', y=1.02)\n",
    "plt.tight_layout()\n",
    "plt.savefig('plots/02_raw_distributions.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "\n",
    "# In[8]:\n",
    "\n",
    "\n",
    "# Correlation heatmap of raw numeric features\n",
    "numeric_cols = df.select_dtypes(include=[np.number]).columns.tolist()\n",
    "if len(numeric_cols) > 1:\n",
    "    corr_matrix = df[numeric_cols].corr()\n",
    "\n",
    "    fig, ax = plt.subplots(figsize=(14, 10))\n",
    "    mask = np.triu(np.ones_like(corr_matrix, dtype=bool))\n",
    "    sns.heatmap(corr_matrix, mask=mask, annot=True, fmt='.2f', cmap='RdBu_r',\n",
    "                center=0, square=True, linewidths=0.5, ax=ax,\n",
    "                cbar_kws={'shrink': 0.8})\n",
    "    ax.set_title('Feature Correlation Matrix', fontsize=14, fontweight='bold')\n",
    "    plt.tight_layout()\n",
    "    plt.savefig('plots/03_correlation_matrix.png', dpi=150, bbox_inches='tight')\n",
    "    plt.show()\n",
    "\n",
    "\n",
    "# ---\n",
    "# ## 4. Feature Engineering\n",
    "\n",
    "# In[9]:\n",
    "\n",
    "\n",
    "class BehavioralRiskModel:\n",
    "    \"\"\"\n",
    "    ML Model to detect risky tax behaviors.\n",
    "    Uses engineered financial ratios + raw compliance metrics.\n",
    "    \"\"\"\n",
    "\n",
    "    REQUIRED_COLUMNS = [\n",
    "        'Revenue', 'Expenses', 'Profit', 'Tax_Liability', 'Tax_Paid',\n",
    "        'Late_Filings', 'Compliance_Violations', 'Tax_Compliance_Ratio',\n",
    "        'Audit_Findings', 'Audit_to_Tax_Ratio'\n",
    "    ]\n",
    "\n",
    "    SELECTED_FEATURES = [\n",
    "        'profit_margin', 'tax_burden', 'expense_ratio', 'payment_gap',\n",
    "        'compliance_score', 'late_filing_penalty', 'violation_penalty',\n",
    "        'audit_risk', 'tax_avoidance_index', 'Late_Filings',\n",
    "        'Compliance_Violations', 'Audit_Findings'\n",
    "    ]\n",
    "\n",
    "    def __init__(self):\n",
    "        self.model = None\n",
    "        self.scaler = None\n",
    "        self.feature_names = None\n",
    "        self.label_encoder = None\n",
    "\n",
    "    def prepare_features(self, df):\n",
    "        \"\"\"Engineer features from raw data.\"\"\"\n",
    "        features = df.copy()\n",
    "\n",
    "        # Ensure required columns exist\n",
    "        for col in self.REQUIRED_COLUMNS:\n",
    "            if col not in features.columns:\n",
    "                features[col] = 0\n",
    "\n",
    "        # Financial ratios\n",
    "        features['profit_margin'] = features['Profit'] / (features['Revenue'] + 1)\n",
    "        features['tax_burden'] = features['Tax_Liability'] / (features['Revenue'] + 1)\n",
    "        features['expense_ratio'] = features['Expenses'] / (features['Revenue'] + 1)\n",
    "        features['payment_gap'] = (features['Tax_Liability'] - features['Tax_Paid']) / (features['Tax_Liability'] + 1)\n",
    "\n",
    "        # Compliance metrics\n",
    "        features['compliance_score'] = features['Tax_Compliance_Ratio']\n",
    "        features['late_filing_penalty'] = features['Late_Filings'] * 0.1\n",
    "        features['violation_penalty'] = features['Compliance_Violations'] * 0.15\n",
    "\n",
    "        # Audit risk indicators\n",
    "        features['audit_risk'] = features['Audit_Findings'] / (features['Audit_to_Tax_Ratio'] + 1)\n",
    "        features['tax_avoidance_index'] = abs(features['Tax_Compliance_Ratio'] - 1)\n",
    "\n",
    "        available = [f for f in self.SELECTED_FEATURES if f in features.columns]\n",
    "        return features[available].fillna(0)\n",
    "\n",
